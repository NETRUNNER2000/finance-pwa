DECLARE
    start_date date;
    end_date date;
BEGIN
    -- start of pay month
    start_date := make_date(p_year, p_month, p_payday);

    -- end = start of next month minus 1 day
    end_date := (start_date + INTERVAL '1 month' - INTERVAL '1 day')::date;

RETURN QUERY
SELECT 
    t.category,
    t.transaction_type,
    SUM(t.amount) AS total
FROM transactions t
WHERE t.user_id = p_user_id
  AND t.transaction_date >= start_date
  AND t.transaction_date <= end_date
GROUP BY t.category, t.transaction_type
ORDER BY t.transaction_type, t.category;
END;